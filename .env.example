# LLM provider — any OpenAI-compatible endpoint (vLLM, Ollama, or hosted).
# vLLM:   LLM_BASE_URL=http://localhost:8001/v1
# Ollama: LLM_BASE_URL=http://localhost:11434/v1   (model e.g. qwen2.5-coder:14b)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=sk-no-key-required
LLM_MODEL=qwen2.5-coder:14b
LLM_TEMPERATURE=0.2

# Where per-tenant git working trees and published sites live (absolute or relative to repo root).
TENANTS_ROOT=./data/tenants
SITES_ROOT=./data/sites

# Voice input (STT) — OPTIONAL, self-hosted OpenAI-compatible transcription
# (e.g. faster-whisper-server). Leave unset to disable the mic button.
# STT_BASE_URL=http://localhost:8000/v1
# STT_MODEL=Systran/faster-whisper-base
# STT_API_KEY=
# STT_LANGUAGE=ru
