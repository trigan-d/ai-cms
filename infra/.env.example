# Copied to infra/.env by bootstrap.sh — values filled in by the script.
# DO NOT commit infra/.env. Real secrets live only on the VPS.

# ─── Postgres ───
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_PASSWORD=

# ─── Supabase JWT ───
# HS256 secret signs ANON_KEY and SERVICE_ROLE_KEY.
JWT_SECRET=
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

# ─── Realtime / Phoenix ───
SECRET_KEY_BASE=

# ─── Storage ───
STORAGE_TENANT_ID=stub
REGION=stub
GLOBAL_S3_BUCKET=stub
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=

# ─── Public URLs ───
APP_PUBLIC_URL=https://platform.ru
API_EXTERNAL_URL=https://api.platform.ru
SUPABASE_PUBLIC_URL=https://api.platform.ru
SITE_URL=https://platform.ru
ADDITIONAL_REDIRECT_URLS=https://platform.ru

# ─── Self-hosted LLM (Ollama) ───
# Model the editing agent uses. llama3.1:8b chains multi-step edits reliably; pull it
# into the ollama container: `docker compose exec ollama ollama pull llama3.1:8b`.
LLM_MODEL=llama3.1:8b

# ─── Wildcard TLS (DNS-01) ───
# API token for your DNS provider so Caddy can issue *.platform.ru via DNS-01.
# The caddy image must be built with the matching caddy-dns plugin (see README).
DNS_API_TOKEN=

# ─── Domains / custom domains (R5) ───
PLATFORM_BASE_DOMAIN=platform.ru
# For verifying a client's custom domain points here (one or both):
CUSTOM_DOMAIN_CNAME=cname.platform.ru
PLATFORM_IP=

# ─── Voice input (R3, optional) ───
# Enable by uncommenting the `whisper` service in docker-compose.yml and setting:
# STT_BASE_URL=http://whisper:8000/v1
STT_MODEL=Systran/faster-whisper-base
STT_LANGUAGE=ru
